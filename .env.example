# Database
DATABASE_URL=postgresql+psycopg://worldcup:worldcup@postgres:5432/worldcup

# Odds Provider (The Odds API — get a free key at https://the-odds-api.com)
ODDS_API_KEY=replace_me

# Admin password hash — generate with: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
# Must be a real bcrypt hash; do not deploy with replace_me.
ADMIN_PASSWORD_HASH=

# Session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_me

# App
APP_BASE_URL=http://localhost:3000
ENVIRONMENT=development
TIMEZONE=America/Mexico_City

# Exports directory (used inside the container)
EXPORT_DIR=/app/exports
